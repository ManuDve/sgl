# ═══════════════════════════════════════════════════════════════════════════════
# SGL — Variables de entorno para producción
# Copia este archivo: cp .env.example .env  y rellena todos los campos.
# ¡NUNCA subas .env al repositorio!
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_DB=sgl_db
POSTGRES_USER=sgl_user
POSTGRES_PASSWORD=cambia_esto_en_produccion

# ─── Backend — JWT ───────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Genera con: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_de_al_menos_32_caracteres
JWT_EXPIRATION_HOURS=8

# ─── Backend — Admin ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@alexcontreras.cl
# Obligatorio en producción (perfil prod). Sin esta var, la app no arranca.
ADMIN_PASSWORD=cambia_esto_en_produccion

# ─── Backend — CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://alexcontreras.cl

# ─── Email (Mailtrap) ────────────────────────────────────────────────────────
MAILTRAP_API_TOKEN=tu_token_de_mailtrap
MAILTRAP_FROM_EMAIL=no-reply@alexcontreras.cl

# ─── Cloudflare Turnstile (anti-bot en formulario de agendamiento) ────────────
TURNSTILE_SECRET_KEY=tu_secret_key_de_turnstile
# BUILD ARG: se baja al JS del browser en tiempo de build del frontend
PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_de_turnstile

# ─── Transbank Webpay Plus ───────────────────────────────────────────────────
# Para producción real: cambia las credenciales de integración por las de producción
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=tu_api_key_de_transbank
# Valores: integration | production
TRANSBANK_ENV=integration
TRANSBANK_RETURN_URL=https://alexcontreras.cl/api/webpay/commit
TRANSBANK_FRONTEND_URL=https://alexcontreras.cl

# ─── WhatsApp / Twilio ───────────────────────────────────────────────────────
# Dejar en blanco para deshabilitar WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_CONTENT_SID=
TWILIO_PAYMENT_CONTENT_SID=
TWILIO_MENU_CONTENT_SID=

# ─── Recordatorios automáticos ───────────────────────────────────────────────
REMINDER_FIRST_LEAD_MINUTES=1440
REMINDER_SECOND_LEAD_MINUTES=120
REMINDER_CRON=0 0 * * * *
WA_BOT_FRONTEND_URL=https://alexcontreras.cl
WA_BOT_SESSION_TTL_MINUTES=5

# ─── Frontend (build arg, no es una var de runtime del contenedor) ────────────
# /api usa Caddy como proxy. En dev local usar http://localhost:8080/api
PUBLIC_API_URL=/api
