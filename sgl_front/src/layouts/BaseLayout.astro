---
import "../styles/global.css";
import NavbarPublica from "../components/NavbarPublica.astro";

const {
  title = "SGL | Asesoría legal a tu alcance",
  description = "Estudio jurídico en Santiago. Asesoría legal profesional en diversas áreas del derecho. Agenda tu consulta en línea.",
  ogTitle = title,
  ogDescription = description,
  showNav = true,
  forceDark = false,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <!-- Script sin-flash: corre sincrónicamente antes de que el CSS se aplique -->
    <script is:inline define:vars={{ forceDark }}>
      if (!forceDark) {
        var t = localStorage.getItem("sgl-theme");
        if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
      }
    </script>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap"
    />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
  </head>
  <body class="bg-sgl-black text-sgl-white">
    {showNav && <NavbarPublica pathname={Astro.url.pathname} />}
    <slot />
  </body>
</html>
